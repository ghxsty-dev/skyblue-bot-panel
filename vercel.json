{
  "version": 2,
  "routes": [
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/commands/new", "dest": "/command-edit.html" },
    { "src": "/commands/edit", "dest": "/command-edit.html" },
    { "src": "/commands", "dest": "/commands.html" },
    { "src": "/settings", "dest": "/settings.html" },
    { "src": "/logs", "dest": "/logs.html" },
    { "src": "/(.*)", "dest": "/login.html" }
  ]
}
